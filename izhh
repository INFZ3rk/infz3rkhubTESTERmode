local function getChar() return lp.Character end
local function getHRP() local c=getChar(); return c and c:FindFirstChild("HumanoidRootPart") end
local function getHum() local c=getChar(); return c and c:FindFirstChild("Humanoid") end

local function tween(obj, props, t, style, dir)
    TS:Create(obj, TweenInfo.new(t or 0.12, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out), props):Play()
end

local function espDestroy(p)
    if espObjs[p] then
        for _, d in pairs(espObjs[p]) do pcall(function() d.Visible=false; d:Remove() end) end
        espObjs[p] = nil
    end
end

local function espHide(p)
    if espObjs[p] then
        for _, d in pairs(espObjs[p]) do pcall(function() d.Visible=false end) end
    end
end

