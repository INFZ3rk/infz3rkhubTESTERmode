    local lb=Instance.new("TextLabel",row)
    lb.Size=UDim2.new(0.52,0,1,0); lb.Position=UDim2.new(0,10,0,0)
    lb.BackgroundTransparency=1; lb.Text=label; lb.Font=Enum.Font.Gotham; lb.TextSize=13
    lb.TextColor3=C.light; lb.TextXAlignment=Enum.TextXAlignment.Left; lb.ZIndex=4

    local pill=Instance.new("TextButton",row)
    pill.Size=UDim2.new(0,56,0,26); pill.Position=UDim2.new(1,-124,0.5,-13)
    pill.BackgroundColor3=Color3.fromRGB(14,30,16); pill.Text="OFF"
    pill.Font=Enum.Font.GothamBold; pill.TextSize=11
    pill.TextColor3=Color3.fromRGB(45,90,55); pill.BorderSizePixel=0; pill.ZIndex=4
    Instance.new("UICorner",pill).CornerRadius=UDim.new(0,6)

    local kb=Instance.new("TextButton",row)
    kb.Size=UDim2.new(0,56,0,26); kb.Position=UDim2.new(1,-62,0.5,-13)
    kb.BackgroundColor3=Color3.fromRGB(8,18,10); kb.Font=Enum.Font.Gotham; kb.TextSize=10
    kb.TextColor3=C.green; kb.BorderSizePixel=0; kb.ZIndex=4
    Instance.new("UICorner",kb).CornerRadius=UDim.new(0,6)
    Instance.new("UIStroke",kb).Color=Color3.fromRGB(22,55,28)
    kb.Text = (key and KB[key] and KB[key]~=Enum.KeyCode.Unknown) and KB[key].Name or "KEY"

    local state,waiting=false,false
    local function setState(v)
        state=v
        if key then T[key]=v end
        if v then
            tween(pill,{BackgroundColor3=C.green,TextColor3=C.black},0.13)
            pill.Text="ON"; if onCB then onCB() end
        else
            tween(pill,{BackgroundColor3=Color3.fromRGB(14,30,16),TextColor3=Color3.fromRGB(45,90,55)},0.13)
            pill.Text="OFF"; if offCB then offCB() end
        end
    end
    pill.MouseButton1Click:Connect(function() setState(not state) end)
    kb.MouseButton1Click:Connect(function()
        if waiting then return end; waiting=true
        kb.Text="..."; kb.TextColor3=Color3.fromRGB(100,230,120)
        local c; c=UIS.InputBegan:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.Keyboard then
                if key then KB[key]=inp.KeyCode end
                kb.Text=inp.KeyCode.Name; kb.TextColor3=C.green
                waiting=false; c:Disconnect()
            end
        end)
    end)
    if key then
        refs[key]={
            setState=setState, getState=function() return state end,
            resetKey=function() KB[key]=Enum.KeyCode.Unknown; kb.Text="KEY"; kb.TextColor3=C.green end
        }
    end
    return row, setState
end

