    local lb=Instance.new("TextLabel",row)
    lb.Size=UDim2.new(1,-10,0,22); lb.Position=UDim2.new(0,10,0,5)
    lb.BackgroundTransparency=1; lb.Text=label..":  "..tostring(def)
    lb.Font=Enum.Font.Gotham; lb.TextSize=12; lb.TextColor3=C.light
    lb.TextXAlignment=Enum.TextXAlignment.Left; lb.ZIndex=4

    local tr=Instance.new("Frame",row)
    tr.Size=UDim2.new(1,-20,0,8); tr.Position=UDim2.new(0,10,0,38)
    tr.BackgroundColor3=Color3.fromRGB(14,30,16); tr.BorderSizePixel=0; tr.ZIndex=4
    Instance.new("UICorner",tr).CornerRadius=UDim.new(0,4)

    local fl=Instance.new("Frame",tr)
    fl.Size=UDim2.new((def-mn)/(mx-mn),0,1,0); fl.BackgroundColor3=C.green2
    fl.BorderSizePixel=0; fl.ZIndex=5
    Instance.new("UICorner",fl).CornerRadius=UDim.new(0,4)

    local hd=Instance.new("Frame",fl)
    hd.Size=UDim2.new(0,14,0,14); hd.AnchorPoint=Vector2.new(0.5,0.5)
    hd.Position=UDim2.new(1,0,0.5,0); hd.BackgroundColor3=C.white
    hd.BorderSizePixel=0; hd.ZIndex=6
    Instance.new("UICorner",hd).CornerRadius=UDim.new(1,0)

    local drag=false
    local function upd(x)
        local pct=math.clamp((x-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
        local val=math.floor(mn+pct*(mx-mn))
        fl.Size=UDim2.new(pct,0,1,0); lb.Text=label..":  "..tostring(val)
        if cb then cb(val) end
    end
    tr.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true; upd(i.Position.X) end
    end)
    tr.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
    end)
    local sc=UIS.InputChanged:Connect(function(i)
        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then upd(i.Position.X) end
    end)
    table.insert(conns,sc)
end

local function btn(parent,text,col,cb)
    col=col or Color3.fromRGB(10,22,12)
    local b=Instance.new("TextButton",parent)
    b.Size=UDim2.new(1,0,0,38); b.BackgroundColor3=col; b.Text=text
    b.Font=Enum.Font.GothamBold; b.TextSize=13; b.TextColor3=C.white
    b.BorderSizePixel=0; b.ZIndex=3
    Instance.new("UICorner",b).CornerRadius=UDim.new(0,8)
    local og=col
    b.MouseEnter:Connect(function() tween(b,{BackgroundColor3=Color3.new(math.min(og.R+.08,1),math.min(og.G+.1,1),math.min(og.B+.06,1))},0.1) end)
    b.MouseLeave:Connect(function() tween(b,{BackgroundColor3=og},0.1) end)
    b.MouseButton1Click:Connect(cb); return b
end

local function inf(parent,text,h)
