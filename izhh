-- ================================================================
--  RENDERSTEPPED
-- ================================================================
local rsConn=RS.RenderStepped:Connect(function(dt)

    if T.fakelag then
        fakeCounter=(fakeCounter+1)%(SL.fakelagFrames+1)
        if fakeCounter~=0 then return end
    end

    local char=getChar(); if not char then return end
    local hrp=char:FindFirstChild("HumanoidRootPart")
    local hum=char:FindFirstChild("Humanoid")

    if T.noclip then
        for _,p in pairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide=false end
        end
    end

    if T.speed and hum then hum.WalkSpeed=SL.walkSpeed end
    if T.infJump and hum then hum.JumpPower=SL.jumpPower end

    if T.godMode and hum and hum.Health<hum.MaxHealth then
        hum.Health=hum.MaxHealth
    end

    if T.autoHeal and hum and hum.MaxHealth<math.huge then
        if hum.Health/hum.MaxHealth*100 < SL.healThreshold then
            hum.Health=hum.MaxHealth
        end
    end

    if T.invisible then
        for _,p in pairs(char:GetDescendants()) do
            if p:IsA("BasePart") and p.Name~="HumanoidRootPart" then
                p.LocalTransparencyModifier=1
            end
        end
    end

    if T.spinBot and hrp then
        hrp.CFrame=hrp.CFrame*CFrame.Angles(0,math.rad(SL.spinSpeed),0)
    end

    if T.antiRagdoll then
        for _,j in pairs(char:GetDescendants()) do
            if j:IsA("Motor6D") then j.Enabled=true end
        end
    end

    if T.autoRespawn and hum and hum.Health<=0 then
        task.delay(0.6,function()
            local h2=lp.Character and lp.Character:FindFirstChild("Humanoid")
            if h2 and h2.Health<=0 then pcall(function() lp:LoadCharacter() end) end
        end)
    end

    if T.hitboxExpand then
        for _,p in pairs(PLS:GetPlayers()) do
            if p~=lp and p.Character then
                local head=p.Character:FindFirstChild("Head")
                if head then
                    pcall(function() head.Size=Vector3.new(SL.hitboxSize,SL.hitboxSize,SL.hitboxSize) end)
                    hitboxParts[p]=head
                end
            end
        end
    end

    if T.followPlayer and followTarget and followTarget.Character then
        local tHRP=followTarget.Character:FindFirstChild("HumanoidRootPart")
        if tHRP and hrp then
            if (hrp.Position-tHRP.Position).Magnitude>SL.followDist then
                local dir=(tHRP.Position-hrp.Position).Unit
                hrp.CFrame=hrp.CFrame:Lerp(CFrame.new(tHRP.Position-dir*SL.followDist),0.1)
            end
        end
    end

    -- FLY
    if flyActive and T.fly and hrp then
        if not hrp:FindFirstChild("FlyBV") then
            local bv=Instance.new("BodyVelocity",hrp)
            bv.Name="FlyBV"; bv.MaxForce=Vector3.new(1e6,1e6,1e6); bv.Velocity=Vector3.new(0,0,0)
            local bg=Instance.new("BodyGyro",hrp)
            bg.Name="FlyBG"; bg.MaxTorque=Vector3.new(1e6,1e6,1e6); bg.P=1e5; bg.CFrame=hrp.CFrame
        end
        local bv=hrp:FindFirstChild("FlyBV"); local bg=hrp:FindFirstChild("FlyBG")
        if bv and bg then
            local mv=Vector3.new()
            if UIS:IsKeyDown(Enum.KeyCode.W) then mv+=cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S) then mv-=cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then mv-=cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D) then mv+=cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space)     then mv+=Vector3.new(0,1,0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then mv-=Vector3.new(0,1,0) end
            bv.Velocity=mv.Magnitude>0 and mv.Unit*SL.flySpeed or Vector3.new(0,0,0)
            bg.CFrame=CFrame.new(hrp.Position,hrp.Position+cam.CFrame.LookVector)
        end
    elseif not flyActive and hrp then
        if hrp:FindFirstChild("FlyBV") then hrp.FlyBV:Destroy() end
        if hrp:FindFirstChild("FlyBG") then hrp.FlyBG:Destroy() end
    end

    -- ESP
    local anyEsp = T.espNames or T.espHealth or T.espLines or T.espDist

    for _,p in pairs(PLS:GetPlayers()) do
        if p==lp then continue end

        if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then
            espDestroy(p); continue
        end

        local head=p.Character:FindFirstChild("Head")
        if not head then espDestroy(p); continue end

        if anyEsp then
            if not espObjs[p] then
                espObjs[p]={}
                local ok2,nm=pcall(function() return Drawing.new("Text") end)
                if ok2 then nm.Size=13; nm.Color=C.white; nm.Outline=true; nm.Visible=false; nm.Text=p.Name; espObjs[p].name=nm end
                local ok3,ln=pcall(function() return Drawing.new("Line") end)
                if ok3 then ln.Thickness=1; ln.Color=C.green; ln.Visible=false; espObjs[p].line=ln end
                local ok4,hp=pcall(function() return Drawing.new("Square") end)
                if ok4 then hp.Thickness=0; hp.Filled=true; hp.Visible=false; espObjs[p].hpBar=hp end
                local ok5,dl=pcall(function() return Drawing.new("Text") end)
                if ok5 then dl.Size=11; dl.Color=C.green2; dl.Outline=true; dl.Visible=false; espObjs[p].distLbl=dl end
            end

            local pos2D,onScreen=cam:WorldToViewportPoint(head.Position)

            if onScreen and pos2D.Z>0 then
                local dist=(cam.CFrame.Position-head.Position).Magnitude
                local sc=math.clamp(1200/dist,8,70)
                local bx2=pos2D.X-sc*0.5; local by2=pos2D.Y-sc*0.6
                local bh=sc*1.8

                if espObjs[p].name then
                    espObjs[p].name.Position=Vector2.new(bx2,by2-16)
                    espObjs[p].name.Visible=T.espNames
                end
                if espObjs[p].line then
                    espObjs[p].line.From=Vector2.new(cam.ViewportSize.X*0.5,cam.ViewportSize.Y)
                    espObjs[p].line.To=Vector2.new(pos2D.X,pos2D.Y)
                    espObjs[p].line.Visible=T.espLines
                end
                if espObjs[p].hpBar then
                    local pH=p.Character:FindFirstChild("Humanoid")
                    local pct=pH and (pH.Health/math.max(pH.MaxHealth,1)) or 1
                    local barH=bh*pct
                    espObjs[p].hpBar.Position=Vector2.new(bx2-7,by2+bh-barH)
                    espObjs[p].hpBar.Size=Vector2.new(4,barH)
                    espObjs[p].hpBar.Color=Color3.new(1-pct,pct,0)
                    espObjs[p].hpBar.Visible=T.espHealth
                end
                if espObjs[p].distLbl then
                    espObjs[p].distLbl.Position=Vector2.new(bx2,by2+bh+2)
                    espObjs[p].distLbl.Text=string.format("%.0fm",dist)
                    espObjs[p].distLbl.Visible=T.espDist
                end
            else
                espHide(p)
            end
        else
            espDestroy(p)
        end
    end
end)
