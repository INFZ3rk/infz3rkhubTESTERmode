NotifGui.Parent=game.CoreGui

local notifList = {}
local N_H, N_G, N_W = 56, 5, 300

local function rebuildPos()
    for i, fr in ipairs(notifList) do
        local ty = 12 + (i-1)*(N_H+N_G)
        tween(fr, {Position=UDim2.new(1,-N_W-12,0,ty)}, 0.2)
    end
end

local function notify(msg, col)
    col = col or C.green
    local fr = Instance.new("Frame")
    fr.Size=UDim2.new(0,N_W,0,N_H); fr.Position=UDim2.new(1,14,0,12)
    fr.BackgroundColor3=Color3.fromRGB(6,14,8); fr.BorderSizePixel=0
    fr.Parent=NotifGui
    Instance.new("UICorner",fr).CornerRadius=UDim.new(0,9)
    local st=Instance.new("UIStroke",fr); st.Color=col; st.Thickness=1.3

    local acc=Instance.new("Frame",fr)
    acc.Size=UDim2.new(0,3,1,-10); acc.Position=UDim2.new(0,0,0,5)
    acc.BackgroundColor3=col; acc.BorderSizePixel=0
    Instance.new("UICorner",acc).CornerRadius=UDim.new(0,3)

    local lb=Instance.new("TextLabel",fr)
    lb.Size=UDim2.new(1,-18,0.78,0); lb.Position=UDim2.new(0,13,0,4)
    lb.BackgroundTransparency=1; lb.Text=msg
    lb.Font=Enum.Font.Gotham; lb.TextSize=13
    lb.TextColor3=C.white; lb.TextXAlignment=Enum.TextXAlignment.Left
    lb.TextWrapped=true

    local bar=Instance.new("Frame",fr)
    bar.Size=UDim2.new(1,0,0,3); bar.Position=UDim2.new(0,0,1,-3)
    bar.BackgroundColor3=col; bar.BorderSizePixel=0
    Instance.new("UICorner",bar).CornerRadius=UDim.new(0,2)

    table.insert(notifList, fr)
    rebuildPos()

    task.spawn(function()
        local steps=80
        for i=steps,0,-1 do
            if bar.Parent then bar.Size=UDim2.new(i/steps,0,0,3) end
            task.wait(3.5/steps)
        end
        tween(fr,{Position=UDim2.new(1,14,0,fr.AbsolutePosition.Y-NotifGui.AbsolutePosition.Y)},0.28,Enum.EasingStyle.Quint,Enum.EasingDirection.In)
        task.wait(0.32)
        for i,f in ipairs(notifList) do if f==fr then table.remove(notifList,i); break end end
        fr:Destroy(); rebuildPos()
    end)
end

