-- ================================================================
local ic=UIS.InputBegan:Connect(function(inp,gp)
    if gp then return end

    if inp.KeyCode==Enum.KeyCode.M and UIReady then
        local v=not MF.Visible; MF.Visible=v; Glow.Visible=v
    end

    if inp.KeyCode==Enum.KeyCode.Q and T.aimbot and not locking then
        locking=true
        local best,bestD=nil,math.huge
        local ctr=cam.ViewportSize/2
        for _,p in pairs(PLS:GetPlayers()) do
            if p~=lp and p.Character then
                for _,pn in ipairs({"Head","UpperTorso","HumanoidRootPart"}) do
                    local part=p.Character:FindFirstChild(pn)
                    if part then
                        local pos,on=cam:WorldToViewportPoint(part.Position)
                        if on and pos.Z>0 then
                            local d=(Vector2.new(pos.X,pos.Y)-ctr).Magnitude
                            if d<bestD and d<SL.aimbotDist then bestD=d; best=part end
                        end
                    end
                end
            end
        end
        if best then
            local st=tick(); local c
            c=RS.RenderStepped:Connect(function()
                if tick()-st>=lockTime or not T.aimbot or not best or not best.Parent then
                    c:Disconnect(); locking=false; return
                end
                cam.CFrame=CFrame.new(cam.CFrame.Position,best.Position)
            end)
        else locking=false; notify("Aimbot: no target found",C.red) end
    end

    if inp.KeyCode==Enum.KeyCode.Z and T.teleport then
        local hrp=getHRP(); if hrp then
            local m=lp:GetMouse()
            hrp.CFrame=CFrame.new(m.Hit.Position+Vector3.new(0,3,0))
            notify("Teleported",C.green)
        end
    end

    if inp.KeyCode==Enum.KeyCode.F and T.fly then
        flyActive=not flyActive
        notify(flyActive and "🛸 Fly ACTIVE" or "🛸 Fly PAUSED", flyActive and C.green or C.red)
    end

    if inp.KeyCode==Enum.KeyCode.Space and T.longJump and UIS:IsKeyDown(Enum.KeyCode.LeftShift) then
        local hrp=getHRP(); if hrp then
            local bv=Instance.new("BodyVelocity")
            bv.Velocity=cam.CFrame.LookVector*120+Vector3.new(0,80,0)
            bv.MaxForce=Vector3.new(1e6,1e6,1e6); bv.Parent=hrp; DB:AddItem(bv,0.2)
        end
    end

    for key,code in pairs(KB) do
        if code~=Enum.KeyCode.Unknown and inp.KeyCode==code
           and key~="aimbot" and key~="teleport" and key~="fly" then
            local r=refs[key]; if r then r.setState(not r.getState()) end
        end
    end
end)
table.insert(conns,ic)

local jc=UIS.InputBegan:Connect(function(inp)
    if inp.KeyCode==Enum.KeyCode.Space and (T.infJump or T.bunnyHop) then
        local h=getHum(); if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end)
